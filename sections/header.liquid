{%- liquid
  # Liens de navigation. Les réglages url-type étant vides par défaut dans le
  # customizer, on garantit des liens fonctionnels via un fallback (le guard
  # `== blank` couvre nil ET chaîne vide). Surchageable dans le thème.
  assign subscribe_url    = section.settings.subscribe_url
  if subscribe_url == blank
    assign subscribe_url = '/#abonnement'
  endif
  assign box_url          = section.settings.box_url
  if box_url == blank
    assign box_url = '/pages/la-box'
  endif
  assign artisans_url     = section.settings.artisans_url
  if artisans_url == blank
    assign artisans_url = '/pages/nos-artisans'
  endif
  assign magazine_url     = section.settings.magazine_url
  if magazine_url == blank
    assign magazine_url = '/pages/magazine'
  endif
  assign story_url        = section.settings.story_url
  if story_url == blank
    assign story_url = '/#notre-histoire'
  endif
  assign faq_url          = section.settings.faq_url
  if faq_url == blank
    assign faq_url = '/pages/faq'
  endif
  assign contact_url      = section.settings.contact_url | default: '/pages/contact'
  assign logo_text        = section.settings.logo_text     | default: 'Maison Bonjour'
  assign edition_label    = section.settings.edition_label | default: 'Édition 01 · Bretagne'
  assign delivery_label   = section.settings.delivery_label| default: 'Livraison le 15 du mois'
-%}

<header class="mb-header" data-mb-header role="banner">

  <div class="mb-header__main">
    <div class="mb-header__inner">

      <nav class="mb-header__nav mb-header__nav--left" aria-label="Navigation principale">
        <a class="mb-header__mark" href="{{ routes.root_url }}" aria-label="{{ logo_text }} — {{ 'header.home' | t }}">
          <img class="mb-header__mark-img mb-header__mark-img--marine"
               src="{{ 'Cartedevizitare-removebg-preview.png' | asset_url }}"
               alt="" width="98" height="56" loading="eager" decoding="async">
          <img class="mb-header__mark-img mb-header__mark-img--cream"
               src="{{ 'maison_bonjour_dark_v2-removebg-preview.png' | asset_url }}"
               alt="" width="98" height="56" loading="eager" decoding="async">
        </a>
        <a class="mb-header__link" href="{{ box_url }}">{{ 'header.nav.box' | t }}</a>
        <a class="mb-header__link" href="{{ artisans_url }}">{{ 'header.nav.artisans' | t }}</a>
        <a class="mb-header__link" href="{{ story_url }}">{{ 'header.nav.story' | t }}</a>
        <a class="mb-header__link" href="{{ magazine_url }}">{{ 'header.nav.magazine' | t }}</a>
      </nav>

      <a class="mb-header__logo" href="{{ routes.root_url }}" aria-label="{{ logo_text }} — {{ 'header.home' | t }}">
        <span class="mb-header__logo-text">{{ logo_text }}</span>
      </a>

      <nav class="mb-header__nav mb-header__nav--right" aria-label="Navigation secondaire">
        <a class="mb-header__link" href="{{ subscribe_url }}">{{ 'header.nav.subscribe' | t }}</a>

        {%- if localization.available_languages.size > 1 -%}
          {%- form 'localization', class: 'mb-lang', id: 'MbLangDesktop' -%}
            <span class="mb-lang__sr">{{ 'language.label' | t }}</span>
            {%- for language in localization.available_languages -%}
              <button
                type="submit"
                name="locale_code"
                value="{{ language.iso_code }}"
                class="mb-lang__opt{% if language.iso_code == localization.language.iso_code %} is-active{% endif %}"
                lang="{{ language.iso_code }}"
                {% if language.iso_code == localization.language.iso_code %}aria-current="true"{% endif %}>
                {{ language.iso_code | slice: 0, 2 | upcase }}
              </button>
            {%- endfor -%}
          {%- endform -%}
        {%- endif -%}

        {%- if shop.customer_accounts_enabled -%}
          <a class="mb-header__icon" href="{{ routes.account_url }}" aria-label="{{ 'header.account' | t }}">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="8" r="3.6"/>
              <path d="M4.5 20c0-4 3.4-7.2 7.5-7.2s7.5 3.2 7.5 7.2"/>
            </svg>
          </a>
        {%- endif -%}

        <a class="mb-header__icon mb-header__cart" href="{{ routes.cart_url }}" aria-label="{{ 'header.cart' | t: count: cart.item_count }}">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M4 6h16l-1.5 12.5a2 2 0 0 1-2 1.75H7.5a2 2 0 0 1-2-1.75L4 6z"/>
            <path d="M9 6V4a3 3 0 0 1 6 0v2"/>
          </svg>
          <span class="mb-header__cart-count{% if cart.item_count == 0 %} is-empty{% endif %}" data-mb-cart-count>{{ cart.item_count }}</span>
        </a>

        <button
          class="mb-header__burger"
          type="button"
          aria-label="{{ 'header.open_menu' | t }}"
          aria-expanded="false"
          aria-controls="MbMobileNav"
          data-mb-menu-toggle>
          <span></span><span></span>
        </button>
      </nav>

    </div>
  </div>
</header>

<div class="mb-mobile-nav" id="MbMobileNav" data-mb-mobile-nav aria-hidden="true">
  <button
    class="mb-mobile-nav__close"
    type="button"
    aria-label="{{ 'header.close_menu' | t }}"
    data-mb-menu-close>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" aria-hidden="true">
      <path d="M5 5l14 14M19 5L5 19"/>
    </svg>
  </button>

  <div class="mb-mobile-nav__inner">
    <a class="mb-mobile-nav__brand" href="{{ routes.root_url }}" aria-label="{{ logo_text }} — {{ 'header.home' | t }}">
      <img class="mb-mobile-nav__brand-img"
           src="{{ 'maison_bonjour_dark_v2-removebg-preview.png' | asset_url }}"
           alt="Maison Bonjour"
           width="252"
           height="144"
           loading="lazy"
           decoding="async">
    </a>
    <nav class="mb-mobile-nav__nav" aria-label="Navigation mobile">
      <a class="mb-mobile-nav__link" href="{{ box_url }}">{{ 'header.nav.box' | t }}</a>
      <a class="mb-mobile-nav__link" href="{{ artisans_url }}">{{ 'header.nav.artisans' | t }}</a>
      <a class="mb-mobile-nav__link" href="{{ story_url }}">{{ 'header.nav.story' | t }}</a>
      <a class="mb-mobile-nav__link" href="{{ magazine_url }}">{{ 'header.nav.magazine' | t }}</a>
      <a class="mb-mobile-nav__link" href="{{ subscribe_url }}">{{ 'header.nav.subscribe' | t }}</a>
    </nav>
    <div class="mb-mobile-nav__sub">
      <a href="{{ faq_url }}">{{ 'header.nav.faq' | t }}</a>
      <a href="{{ contact_url }}">{{ 'header.nav.contact' | t }}</a>
      <a href="{{ routes.account_url }}">{{ 'header.account' | t }}</a>
    </div>

    {%- if localization.available_languages.size > 1 -%}
      {%- form 'localization', class: 'mb-lang mb-lang--mobile', id: 'MbLangMobile' -%}
        <span class="mb-lang__sr">{{ 'language.label' | t }}</span>
        {%- for language in localization.available_languages -%}
          <button
            type="submit"
            name="locale_code"
            value="{{ language.iso_code }}"
            class="mb-lang__opt{% if language.iso_code == localization.language.iso_code %} is-active{% endif %}"
            lang="{{ language.iso_code }}"
            {% if language.iso_code == localization.language.iso_code %}aria-current="true"{% endif %}>
            {{ language.iso_code | slice: 0, 2 | upcase }}
          </button>
        {%- endfor -%}
      {%- endform -%}
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  /* ===========================================================
     HEADER — minimaliste, une seule barre, hiérarchie pure
     =========================================================== */

  .mb-header {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 500;
    color: var(--marine);
    transform: translateY(-100%);
    animation: header-drop 0.9s cubic-bezier(0.18, 1.1, 0.24, 1) 0.35s forwards;
    transition: color 0.3s ease;
  }

  @keyframes header-drop { to { transform: translateY(0); } }

  /* --- Single bar --- */

  .mb-header__main {
    background: transparent;
    border-bottom: 1px solid transparent;
    transition:
      background 0.4s ease,
      backdrop-filter 0.4s ease,
      border-color 0.4s ease;
  }

  .mb-header__inner {
    /* Pas de position:relative ici : on veut que .mb-header__mark (absolute)
       s'ancre au .mb-header (fixed = viewport), pas à ce conteneur max-width centré.
       Le mobile media query rétablit position:relative pour le wordmark centré mobile. */
    max-width: var(--container);
    margin-inline: auto;
    padding: 18px clamp(20px, 4vw, 56px);
    display: grid;
    /* minmax(0, 1fr) force les deux colonnes latérales à être STRICTEMENT égales
       (chacune la moitié de l'espace restant) : sans le min:0, un côté plus large
       (4 liens à gauche vs 1 à droite) ferait grossir sa piste et décentrerait le
       wordmark. Ici la colonne auto centrale reste géométriquement centrée. */
    grid-template-columns: minmax(0, 1fr) auto minmax(0, 1fr);
    align-items: center;
    gap: clamp(32px, 5vw, 72px);
    min-height: 64px;
  }

  /* --- Nav clusters --- */

  .mb-header__nav {
    display: flex;
    align-items: center;
    /* Gap volontairement resserré : le contenu est plafonné à --container (1240px)
       donc même sur grand écran l'espace utile est limité. Avec 4 liens à gauche,
       un gap large ferait toucher « Magazine » au wordmark central. */
    gap: clamp(16px, 1.8vw, 24px);
  }
  /* On groupe les clusters autour du wordmark central plutôt que de les coller
     aux bords : le cluster gauche s'aligne vers la droite de sa colonne (donc
     près du titre), le droit vers la gauche de la sienne. Résultat : espacement
     régulier autour de « MAISON BONJOUR », plus de grand vide déséquilibré.
     Le gap de la grille gère la distance au wordmark. */
  .mb-header__nav--left  { justify-self: end; }
  .mb-header__nav--right { justify-self: start; }

  .mb-header__link {
    position: relative;
    padding: 6px 0;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 400;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: currentColor;
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.3s ease, opacity 0.3s ease;
    opacity: 0.85;
  }
  .mb-header__link::after {
    content: "";
    position: absolute;
    left: 0; right: 0;
    bottom: 2px;
    height: 1px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left center;
    opacity: 0.6;
    transition: transform 0.5s cubic-bezier(0.18, 1, 0.22, 1);
  }
  .mb-header__link:hover { opacity: 1; color: var(--gold); }
  .mb-header__link:hover::after { transform: scaleX(1); }

  /* Logo PNG transparent — DANS LE FLUX du cluster nav gauche (premier enfant flex).
     Auparavant en position:absolute ancré au viewport, ce qui faisait démarrer les
     liens « La Box / Notre histoire / Magazine » SOUS le logo → chevauchement.
     En flux, le `gap` du cluster réserve naturellement l'espace : plus aucun
     recouvrement, à toutes les largeurs (1440 → 1024). Le logo reste contenu
     dans la colonne gauche de la grille, donc le wordmark central reste centré.
     Deux variantes (marine / cream) superposées, swap par CSS selon le contexte. */
  .mb-header__mark {
    position: relative;
    z-index: 3;
    display: inline-flex;
    align-items: center;
    flex: 0 0 auto;
    line-height: 0;
    text-decoration: none;
    transition: opacity 0.3s ease;
  }
  .mb-header__mark:hover { opacity: 0.75; }
  /* Les deux versions sont superposées : marine en relative (définit la taille
     du conteneur), cream en absolute par-dessus. On crossfade via opacity pour
     un swap doux comme les textes qui changent de couleur au scroll.
     Hauteur réduite et fluide → logo jamais trop large sur desktop. */
  .mb-header__mark-img {
    display: block;
    width: auto;
    height: clamp(44px, 4vw, 54px);
    transition: opacity 0.3s ease;
  }
  .mb-header__mark-img--marine { position: relative; opacity: 1; }
  .mb-header__mark-img--cream  { position: absolute; top: 0; left: 0; opacity: 0; }
  /* Home en haut du hero sombre → fade vers cream. */
  .template-index .mb-header:not(.is-scrolled) .mb-header__mark-img--marine { opacity: 0; }
  .template-index .mb-header:not(.is-scrolled) .mb-header__mark-img--cream  { opacity: 1; }
  /* Drawer mobile ouvert — forte spécificité pour battre TOUTES les autres règles,
     y compris le cas home-scrolled-puis-burger-ouvert où la cascade peut conflicter. */
  body.no-scroll .mb-header .mb-header__mark .mb-header__mark-img--marine { opacity: 0; }
  body.no-scroll .mb-header .mb-header__mark .mb-header__mark-img--cream  { opacity: 1; }
  /* Même chose pour le fond du header : forcer transparent quand le drawer est ouvert
     (sinon sur home scrolled, le fond cream solide reste visible et masque le drawer dark). */
  body.no-scroll .mb-header .mb-header__main,
  body.no-scroll.template-index .mb-header .mb-header__main {
    background: transparent !important;
    border-color: transparent !important;
    -webkit-backdrop-filter: none !important;
            backdrop-filter: none !important;
    box-shadow: none !important;
  }

  /* --- Center logo : wordmark texte centré (inchangé) --- */

  .mb-header__logo {
    justify-self: center;
    display: inline-block;
    text-decoration: none;
    color: currentColor;
    line-height: 1;
    padding: 4px 8px;
    transition: opacity 0.3s ease;
  }
  .mb-header__logo:hover { opacity: 0.75; }

  .mb-header__logo-text {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-style: normal;
    font-weight: 400;
    font-variation-settings: "wdth" 100;
    font-size: clamp(19px, 2vw, 24px);
    letter-spacing: 0.025em;
    line-height: 1;
    text-transform: uppercase;
  }

  /* --- Icons : compte + panier --- */

  .mb-header__icon {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: currentColor;
    opacity: 0.85;
    transition: color 0.3s ease, opacity 0.3s ease;
    line-height: 0;
  }
  .mb-header__icon:hover { color: var(--gold); opacity: 1; }

  .mb-header__cart-count {
    position: absolute;
    top: -6px; right: -8px;
    min-width: 14px;
    height: 14px;
    padding: 0 4px;
    background: var(--gold);
    color: var(--marine-deep);
    font-family: var(--font-sans);
    font-size: 8.5px;
    font-weight: 600;
    line-height: 14px;
    text-align: center;
    border-radius: 999px;
  }
  .mb-header__cart-count.is-empty { display: none; }

  /* --- Sélecteur de langue FR / RO --- */
  /* Discret, aligné sur la typo nav (Inter, uppercase, tracking large).
     Rendu via {% form 'localization' %} : n'apparaît que si ≥ 2 langues
     publiées dans Shopify Admin → Marchés/Langues. */
  .mb-lang {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    margin: 0;
  }
  .mb-lang__sr {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden; clip: rect(0 0 0 0);
    white-space: nowrap; border: 0;
  }
  .mb-lang__opt {
    appearance: none;
    background: transparent;
    border: 0;
    padding: 4px 5px;
    cursor: pointer;
    font-family: var(--font-sans);
    font-size: 10.5px;
    font-weight: 400;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: currentColor;
    opacity: 0.55;
    line-height: 1;
    transition: color 0.3s ease, opacity 0.3s ease;
  }
  .mb-lang__opt:hover { opacity: 1; color: var(--gold); }
  .mb-lang__opt.is-active { opacity: 1; }
  .mb-lang__opt.is-active:hover { color: currentColor; cursor: default; }
  /* Séparateur fin entre les options (FR · RO) */
  .mb-lang__opt + .mb-lang__opt {
    border-left: 1px solid currentColor;
    border-left-color: color-mix(in srgb, currentColor 30%, transparent);
  }
  .mb-lang__opt:focus-visible {
    outline: 1px solid var(--gold);
    outline-offset: 2px;
    opacity: 1;
  }

  /* Variante drawer mobile : centrée, plus aérée, sur fond marine-deep */
  .mb-lang--mobile {
    margin-top: 4px;
    justify-content: center;
    gap: 4px;
  }
  .mb-lang--mobile .mb-lang__opt {
    font-size: 11px;
    letter-spacing: 0.24em;
    padding: 6px 10px;
    color: var(--cream);
    opacity: 0.6;
  }
  .mb-lang--mobile .mb-lang__opt.is-active { opacity: 1; }
  .mb-lang--mobile .mb-lang__opt:hover { color: var(--gold); }

  /* Sur mobile, le sélecteur desktop (dans la nav droite) est masqué :
     il vit dans le drawer. */
  @media (max-width: 767px) {
    .mb-header__nav--right .mb-lang { display: none; }
  }

  /* --- Burger (mobile) --- */

  .mb-header__burger {
    display: none;
    width: 22px;
    height: 14px;
    background: transparent;
    border: 0;
    padding: 0;
    flex-direction: column;
    justify-content: space-between;
    align-items: stretch;
    cursor: pointer;
    color: currentColor;
  }
  .mb-header__burger span {
    display: block;
    height: 1.5px;
    width: 100%;
    background: currentColor;
    transform-origin: center;
    transition:
      transform 0.4s cubic-bezier(0.18, 1, 0.22, 1),
      width 0.3s ease,
      margin 0.3s ease;
  }
  .mb-header__burger span:last-child { width: 65%; margin-left: auto; }

  /* Burger → croix : les deux barres se rejoignent au centre puis pivotent.
     Déclenché par aria-expanded (posé par le JS du toggle, aucun changement JS). */
  .mb-header__burger[aria-expanded="true"] span:first-child {
    transform: translateY(6.25px) rotate(45deg);
  }
  .mb-header__burger[aria-expanded="true"] span:last-child {
    width: 100%;
    margin-left: 0;
    transform: translateY(-6.25px) rotate(-45deg);
  }

  /* ===========================================================
     States : transparent over hero, cream solid scrolled
     =========================================================== */

  /* Sur la home, en haut → texte cream par-dessus le hero sombre */
  .template-index .mb-header { color: var(--cream); }
  .template-index .mb-header__main {
    background: linear-gradient(180deg, rgba(15, 26, 46, 0.35) 0%, rgba(15, 26, 46, 0) 100%);
  }

  /* Sur les autres pages → fond cream discret par défaut */
  .mb-header__main {
    background: rgba(254, 249, 243, 0.92);
    border-bottom-color: rgba(28, 43, 74, 0.06);
    -webkit-backdrop-filter: blur(12px);
            backdrop-filter: blur(12px);
  }

  /* Scrolled → cream solid, séparateur fin, ombre douce */
  .mb-header.is-scrolled { color: var(--marine); }
  .mb-header.is-scrolled .mb-header__main {
    background: rgba(254, 249, 243, 0.94);
    border-bottom-color: rgba(28, 43, 74, 0.08);
    -webkit-backdrop-filter: blur(16px);
            backdrop-filter: blur(16px);
    box-shadow: 0 1px 0 rgba(15, 26, 46, 0.02);
  }
  .template-index .mb-header.is-scrolled .mb-header__main {
    background: rgba(254, 249, 243, 0.94);
  }

  /* ===========================================================
     Responsive
     =========================================================== */

  /* 4 liens à gauche (La Box · Nos artisans · Notre histoire · Magazine) : le
     cluster est large et viendrait chevaucher le wordmark central « MAISON
     BONJOUR ». Sur tout le desktop/tablette on masque le logo image redondant
     de gauche (le wordmark central porte déjà la marque) pour rendre de la place
     aux liens. Le logo image reste visible uniquement en mobile (top-left). */
  @media (min-width: 768px) {
    .mb-header__mark { display: none; }
  }

  /* On resserre gap + tracking dès 1280px pour que les 4 liens gauche +
     « S'abonner à la box » à droite tiennent sans toucher le wordmark central,
     jusqu'au breakpoint mobile (≤767px) où les liens passent au drawer. */
  @media (max-width: 1280px) {
    .mb-header__inner { gap: 16px; }
    .mb-header__nav { gap: clamp(16px, 2vw, 26px); }
    .mb-header__link { font-size: 10px; letter-spacing: 0.16em; }
  }

  @media (max-width: 1024px) {
    .mb-header__inner { gap: 14px; min-height: 60px; padding: 16px clamp(18px, 4vw, 40px); }
    .mb-header__nav { gap: clamp(12px, 1.6vw, 18px); }
    .mb-header__link { font-size: 9.5px; letter-spacing: 0.12em; }
  }

  @media (max-width: 767px) {
    /* Sur mobile on bascule en flex : nav gauche cachée, logo wordmark centré,
       nav droite (icônes + burger) à droite. Le mark top-left reste position:absolute. */
    .mb-header__inner {
      position: relative;
      display: flex;
      align-items: center;
      justify-content: flex-end;
      grid-template-columns: none;
      gap: 14px;
      padding: 14px 16px;
      min-height: 54px;
    }

    /* On garde le conteneur nav-left visible pour que le mark dedans reste affiché ;
       on cache seulement les liens textuels (La Box, Magazine), qui passent dans le drawer. */
    .mb-header__nav--left { display: flex; margin-right: auto; gap: 0; }
    .mb-header__nav--left .mb-header__link { display: none; }

    .mb-header__nav--right {
      display: flex;
      align-items: center;
      gap: 16px;
      justify-self: unset;
    }
    /* On garde les icônes et le burger ; on cache le lien "S'abonner" */
    .mb-header__nav--right .mb-header__link { display: none; }

    .mb-header__burger {
      display: flex;
      justify-self: unset;
    }

    /* Logo wordmark centré géométriquement, indépendant du flux flex */
    .mb-header__logo {
      position: absolute;
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%);
      justify-self: unset;
      pointer-events: auto;
    }

    .mb-header__logo-text { font-size: 20px; }

    /* Mobile : le mark (en flux dans nav--left, qui a margin-right:auto) reste
       collé à gauche ; le wordmark texte est centré géométriquement par-dessus. */
    .mb-header__mark-img { height: 40px; }
  }

  /* ===========================================================
     Mobile nav drawer — sobre, plein écran
     =========================================================== */

  .mb-mobile-nav {
    position: fixed;
    inset: 0;
    z-index: 800;
    background: var(--marine-deep);
    color: var(--cream);
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0s linear 0.4s;
  }
  .mb-mobile-nav.is-open {
    opacity: 1;
    visibility: visible;
    transition: opacity 0.4s ease, visibility 0s linear 0s;
  }

  /* Croix dédiée masquée : c'est désormais le burger qui se morphe en croix. */
  .mb-mobile-nav__close { display: none; }

  /* Menu ouvert (body.no-scroll posé par le JS) : on remonte le header au-dessus
     du drawer pour que le burger-croix reste visible et cliquable, et on efface
     le fond de la barre pour ne garder que le logo + la croix sur le marine. */
  body.no-scroll .mb-header {
    z-index: 900;
    color: var(--cream);
  }
  body.no-scroll .mb-header__main,
  .template-index body.no-scroll .mb-header__main {
    background: transparent;
    border-color: transparent;
    -webkit-backdrop-filter: none;
            backdrop-filter: none;
    box-shadow: none;
  }
  body.no-scroll .mb-header__icon {
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s ease;
  }

  .mb-mobile-nav__inner {
    height: 100%;
    width: 100%;
    padding: 0 24px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 36px;
    text-align: center;
  }

  /* Logo image dans le drawer mobile — version cream sur fond marine-deep. */
  .mb-mobile-nav__brand {
    display: inline-block;
    line-height: 0;
    opacity: 0;
    transform: translateY(14px);
    transition: opacity 0.5s ease, transform 0.6s cubic-bezier(0.18, 1, 0.22, 1);
  }
  .mb-mobile-nav__brand-img {
    display: block;
    width: auto;
    height: clamp(96px, 22vw, 140px);
  }

  .mb-mobile-nav__nav {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .mb-mobile-nav__link {
    font-family: var(--font-serif);
    font-weight: 500;
    font-style: normal;
    font-size: clamp(1.9rem, 7.5vw, 2.8rem);
    line-height: 1;
    letter-spacing: 0.005em;
    color: var(--cream);
    text-decoration: none;
    /* État fermé : décalé vers le bas + masqué, prêt pour le reveal échelonné */
    opacity: 0;
    transform: translateY(22px);
    transition:
      color 0.3s ease,
      opacity 0.5s ease,
      transform 0.6s cubic-bezier(0.18, 1, 0.22, 1);
  }
  .mb-mobile-nav__link:hover { color: var(--gold); }

  .mb-mobile-nav__sub {
    display: flex;
    gap: 22px;
    flex-wrap: wrap;
    justify-content: center;
    margin-top: 8px;
  }
  .mb-mobile-nav__sub a {
    font-family: var(--font-sans);
    font-size: 10px;
    font-weight: 400;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: rgba(250, 246, 236, 0.6);
    text-decoration: none;
    opacity: 0;
    transform: translateY(14px);
    transition:
      color 0.25s ease,
      opacity 0.5s ease,
      transform 0.6s cubic-bezier(0.18, 1, 0.22, 1);
  }
  .mb-mobile-nav__sub a:hover { color: var(--gold); }

  /* Reveal échelonné quand le drawer s'ouvre — les liens montent en cascade */
  .mb-mobile-nav.is-open .mb-mobile-nav__brand,
  .mb-mobile-nav.is-open .mb-mobile-nav__link,
  .mb-mobile-nav.is-open .mb-mobile-nav__sub a {
    opacity: 1;
    transform: translateY(0);
  }
  .mb-mobile-nav.is-open .mb-mobile-nav__link { opacity: 0.92; }
  .mb-mobile-nav.is-open .mb-mobile-nav__link:hover { opacity: 1; }

  .mb-mobile-nav.is-open .mb-mobile-nav__brand          { transition-delay: 0.06s; }
  .mb-mobile-nav.is-open .mb-mobile-nav__link:nth-child(1) { transition-delay: 0.16s; }
  .mb-mobile-nav.is-open .mb-mobile-nav__link:nth-child(2) { transition-delay: 0.23s; }
  .mb-mobile-nav.is-open .mb-mobile-nav__link:nth-child(3) { transition-delay: 0.30s; }
  .mb-mobile-nav.is-open .mb-mobile-nav__link:nth-child(4) { transition-delay: 0.37s; }
  .mb-mobile-nav.is-open .mb-mobile-nav__link:nth-child(5) { transition-delay: 0.44s; }
  .mb-mobile-nav.is-open .mb-mobile-nav__sub a:nth-child(1) { transition-delay: 0.50s; }
  .mb-mobile-nav.is-open .mb-mobile-nav__sub a:nth-child(2) { transition-delay: 0.55s; }
  .mb-mobile-nav.is-open .mb-mobile-nav__sub a:nth-child(3) { transition-delay: 0.60s; }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .mb-header { animation: none; transform: none; }
    .mb-header__link::after,
    .mb-mobile-nav__brand,
    .mb-mobile-nav__link,
    .mb-mobile-nav__sub a { transition: color 0.3s ease; }
    /* Pas de translation : visibles immédiatement, sans cascade */
    .mb-mobile-nav__brand,
    .mb-mobile-nav__link,
    .mb-mobile-nav__sub a { transform: none; opacity: 1; }
    .mb-mobile-nav.is-open .mb-mobile-nav__brand,
    .mb-mobile-nav.is-open .mb-mobile-nav__link,
    .mb-mobile-nav.is-open .mb-mobile-nav__sub a { transition-delay: 0s; }
    .mb-header__burger span { transition: none; }
  }
{% endstylesheet %}

