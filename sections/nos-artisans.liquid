{%- liquid
  # =====================================================================
  # PAGE « NOS ARTISANS »
  # ---------------------------------------------------------------------
  # Hero éditorial + intro courte + une entrée par artisan (blocs schema
  # répétables → on ajoute un nouvel artisan dans le customizer, sans code).
  # On démarre avec Louis Sicard (rendu par défaut si aucun bloc configuré).
  # Style : éditorial, aéré, premium — surtout pas catalogue.
  # =====================================================================
  assign hero_title = section.settings.hero_title | default: 'Nos artisans'
  assign hero_sub   = section.settings.hero_subtitle | default: 'Derrière chaque objet, une maison. Derrière chaque maison, des gestes que le temps n’a pas effacés.'
  assign hero_img   = section.settings.hero_image
  assign intro      = section.settings.intro | default: 'Maison Bonjour ne sélectionne pas seulement des produits. Nous cherchons des maisons, des ateliers, des familles, des gestes transmis. Chaque artisan présenté ici donne à une région sa matière, son parfum ou sa mémoire.'
  assign closing    = section.settings.closing_note | default: 'Chaque mois, de nouvelles maisons rejoindront cette page, au fil des éditions.'
  assign hero_eyebrow = section.settings.hero_eyebrow | default: 'Maison Bonjour · Les maisons'
-%}

<section class="artisans section--cream" aria-label="Nos artisans">

  {%- comment -%} ---- HERO ---- {%- endcomment -%}
  <div class="container artisans__hero">
    <div class="artisans__hero-text reveal">
      {%- if hero_eyebrow != blank -%}
        <p class="label artisans__eyebrow"><span class="artisans__eyebrow-rule" aria-hidden="true"></span>{{ hero_eyebrow }}</p>
      {%- endif -%}
      <h1 class="artisans__title">{{ hero_title }}</h1>
      <p class="artisans__subtitle">{{ hero_sub }}</p>
    </div>
    {%- if hero_img != blank -%}
      <figure class="artisans__hero-media reveal reveal--delay-1">
        {{ hero_img | image_url: width: 1600 | image_tag:
            loading: 'eager',
            fetchpriority: 'high',
            sizes: '(min-width: 1024px) 50vw, 92vw',
            widths: '600, 900, 1200, 1600',
            class: 'artisans__hero-img',
            alt: hero_title }}
      </figure>
    {%- else -%}
      <figure class="artisans__hero-media reveal reveal--delay-1">
        <img class="artisans__hero-img"
             src="{{ 'LouPais_artisans.jpeg' | asset_url }}"
             alt="Les artisans Maison Bonjour, dans leur atelier"
             width="1220" height="1569" loading="eager" fetchpriority="high" decoding="async">
      </figure>
    {%- endif -%}
  </div>

  {%- comment -%} ---- INTRO ÉDITORIALE (rail + déclaration) ---- {%- endcomment -%}
  {%- if intro != blank -%}
    <div class="container artisans__intro reveal">
      <aside class="artisans__rail">
        <span class="artisans__rail-num">—</span>
        <span class="artisans__rail-label">L’esprit</span>
      </aside>
      <p>{{ intro }}</p>
    </div>
  {%- endif -%}

  {%- comment -%} ---- ENTRÉES ARTISANS ---- {%- endcomment -%}
  <div class="container artisans__list">

    {%- if section.blocks.size > 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'artisan' -%}
          <article class="artisan-entry reveal" {{ block.shopify_attributes }}>
            <div class="artisan-entry__text">
              {%- if block.settings.label != blank -%}<p class="label artisan-entry__label">{{ block.settings.label }}</p>{%- endif -%}
              {%- if block.settings.name  != blank -%}<h2 class="artisan-entry__name">{{ block.settings.name }}</h2>{%- endif -%}
              <span class="artisan-entry__rule" aria-hidden="true"></span>
              <div class="artisan-entry__body editorial">{{ block.settings.body }}</div>
            </div>

            {%- assign has_img = false -%}
            {%- if block.settings.image_1 != blank or block.settings.image_2 != blank -%}{%- assign has_img = true -%}{%- endif -%}
            {%- if has_img -%}
              <div class="artisan-entry__photos">
                {%- if block.settings.image_1 != blank -%}
                  {{ block.settings.image_1 | image_url: width: 1200 | image_tag:
                      loading: 'lazy', sizes: '(min-width: 768px) 44vw, 92vw',
                      widths: '500, 800, 1200', class: 'artisan-entry__photo',
                      alt: block.settings.image_1_alt | default: block.settings.name }}
                {%- endif -%}
                {%- if block.settings.image_2 != blank -%}
                  {{ block.settings.image_2 | image_url: width: 1200 | image_tag:
                      loading: 'lazy', sizes: '(min-width: 768px) 44vw, 92vw',
                      widths: '500, 800, 1200', class: 'artisan-entry__photo',
                      alt: block.settings.image_2_alt | default: block.settings.name }}
                {%- endif -%}
              </div>
            {%- endif -%}
          </article>
        {%- endif -%}
      {%- endfor -%}

    {%- else -%}
      {%- comment -%} Aucun bloc configuré : teaser « secret » en attendant le
          dévoilement de la box de juillet 2026. On remplacera ce bloc par les
          vraies entrées artisans (un bloc « Artisan » par maison) fin juillet. {%- endcomment -%}
      <div class="artisans__teaser reveal">
        <p class="label artisans__teaser-kicker">Première édition · Juillet 2026</p>
        <span class="artisans__teaser-rule" aria-hidden="true"></span>
        <p class="artisans__teaser-text">Les maisons que nous avons choisies pour cette première édition restent encore secrètes. Vous les découvrirez une à une, au dévoilement de la box de juillet&nbsp;2026 — car une box garde son charme tant qu’elle ne dit pas tout.</p>
      </div>
    {%- endif -%}

  </div>

  {%- comment -%} Note de clôture discrète — annonce l'arrivée d'autres maisons
      sans inventer de faux artisans ni laisser un vide. {%- endcomment -%}
  {%- if closing != blank and section.blocks.size > 0 -%}
    <div class="container artisans__closing reveal">
      <span class="artisans__closing-rule" aria-hidden="true"></span>
      <p>{{ closing }}</p>
    </div>
  {%- endif -%}
</section>

{% stylesheet %}
  .artisans { padding-block: clamp(96px, 11vw, 160px) clamp(64px, 8vw, 110px); }

  /* Surtitre éditorial */
  .artisans__eyebrow {
    display: inline-flex; align-items: center; gap: 12px;
    color: var(--gold); margin: 0 0 22px;
  }
  .artisans__eyebrow-rule { display: inline-block; width: 28px; height: 1px; background: var(--gold); opacity: 0.75; }

  /* ---- Hero ---- */
  .artisans__hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(32px, 5vw, 56px);
    align-items: center;
  }
  .artisans__title {
    margin: 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2.8rem, 5vw + 1rem, 5.5rem);
    line-height: 1.02;
    letter-spacing: -0.015em;
    color: var(--marine);
  }
  .artisans__subtitle {
    margin: clamp(20px, 2.5vw, 30px) 0 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.3rem, 1vw + 1rem, 1.9rem);
    line-height: 1.4;
    color: var(--text-muted);
    max-width: 30ch;
  }
  /* Cadre « passe-partout » : fond crème + fin filet champagne + léger arrondi,
     ombre douce → l'image n'est plus un carré brut posé. */
  .artisans__hero-media {
    margin: 0;
    padding: clamp(10px, 1.2vw, 16px);
    background: var(--cream-warm);
    border: 1px solid var(--border);
    border-radius: 14px;
    box-shadow: 0 14px 34px rgba(43, 32, 24, 0.08);
  }
  .artisans__hero-img {
    display: block; width: 100%; height: auto;
    aspect-ratio: 4 / 5; object-fit: cover; border-radius: 7px;
  }

  /* ---- Intro éditoriale (rail + grande déclaration) ---- */
  .artisans__intro {
    margin-top: clamp(64px, 8vw, 120px);
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(20px, 3vw, 36px);
  }
  .artisans__rail-num {
    font-family: var(--font-serif); font-style: italic; color: var(--gold);
    font-size: clamp(1.6rem, 2.4vw, 2.4rem); line-height: 1;
  }
  .artisans__rail-label {
    display: block; margin-top: 10px; font-family: var(--font-sans);
    font-size: 11px; font-weight: 600; letter-spacing: 0.28em; text-transform: uppercase; color: var(--marine);
  }
  .artisans__intro p {
    margin: 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.4rem, 1.4vw + 1rem, 2.2rem);
    line-height: 1.4;
    color: var(--marine);
    max-width: 30ch;
  }

  /* ---- Entrées artisans ---- */
  .artisans__list {
    margin-top: clamp(56px, 7vw, 104px);
    display: flex;
    flex-direction: column;
    gap: clamp(64px, 8vw, 120px);
  }
  .artisan-entry {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(28px, 4vw, 48px);
    padding-top: clamp(48px, 6vw, 88px);
    border-top: 1px solid var(--border);
  }
  .artisans__list .artisan-entry:first-child { padding-top: 0; border-top: 0; }

  .artisan-entry__label { color: var(--gold); margin-bottom: 16px; }
  .artisan-entry__name {
    margin: 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(2rem, 2.6vw + 1rem, 3.25rem);
    line-height: 1.04;
    letter-spacing: -0.015em;
    color: var(--marine);
  }
  .artisan-entry__rule {
    display: block; width: 56px; height: 1px;
    margin: 28px 0; background: var(--gold); opacity: 0.7;
  }
  .artisan-entry__body p {
    margin: 0 0 1.2em;
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: clamp(1.02rem, 0.4vw + 0.95rem, 1.15rem);
    line-height: 1.78;
    color: var(--text);
    max-width: 60ch;
  }
  .artisan-entry__body p:last-child { margin-bottom: 0; }

  .artisan-entry__photos {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(14px, 2vw, 22px);
  }
  .artisan-entry__photo {
    display: block; width: 100%; height: auto;
    aspect-ratio: 4 / 5; object-fit: cover;
    border-radius: 10px;
    border: 1px solid var(--border);
    background: var(--cream-warm);
    box-shadow: 0 12px 30px rgba(43, 32, 24, 0.08);
    transition: transform 0.5s var(--ease-out), box-shadow 0.5s var(--ease-out);
  }
  .artisan-entry__photo:hover {
    transform: translateY(-3px);
    box-shadow: 0 18px 40px rgba(43, 32, 24, 0.12);
  }
  /* Première photo (portrait artisans) un peu plus haute → composition asymétrique. */
  .artisan-entry__photo:first-child { aspect-ratio: 3 / 4; }

  /* ---- Desktop : texte + photos côte à côte, alternance élégante ---- */
  @media (min-width: 1024px) {
    .artisans__hero { grid-template-columns: 1fr 1fr; column-gap: clamp(48px, 5vw, 88px); }
    .artisans__intro { grid-template-columns: minmax(120px, 1fr) 3fr; column-gap: clamp(40px, 5vw, 96px); }
    .artisans__intro p { max-width: 42ch; }
    .artisan-entry {
      grid-template-columns: 1fr 1fr;
      column-gap: clamp(48px, 5vw, 88px);
      align-items: start;
    }
    /* Alternance : photos à gauche pour les entrées paires. */
    .artisans__list .artisan-entry:nth-child(even) .artisan-entry__text { order: 2; }
    .artisan-entry__photos { grid-template-columns: 1fr 1fr; }
  }

  /* ---- Teaser « secret » (avant dévoilement box juillet 2026) ---- */
  .artisans__teaser {
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
    padding-block: clamp(24px, 4vw, 48px);
  }
  .artisans__teaser-kicker { color: var(--gold); margin: 0; }
  .artisans__teaser-rule {
    display: block;
    width: 48px;
    height: 1px;
    margin: clamp(20px, 2.5vw, 28px) auto;
    background: var(--gold);
    opacity: 0.7;
  }
  .artisans__teaser-text {
    margin: 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.4rem, 1.2vw + 1rem, 2.1rem);
    line-height: 1.4;
    color: var(--marine);
  }

  /* ---- Note de clôture ---- */
  .artisans__closing {
    margin-top: clamp(56px, 7vw, 104px);
    text-align: center;
    max-width: 620px;
  }
  .artisans__closing { margin-inline: auto; }
  .artisans__closing-rule {
    display: block;
    width: 40px;
    height: 1px;
    margin: 0 auto clamp(20px, 2.5vw, 28px);
    background: var(--gold);
    opacity: 0.7;
  }
  .artisans__closing p {
    margin: 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.1rem, 0.8vw + 0.9rem, 1.4rem);
    line-height: 1.5;
    color: var(--text-muted);
  }

  @media (max-width: 767px) {
    .artisans { padding-block: 88px 56px; }
    .artisans__subtitle { max-width: 100%; }
  }

  @media (prefers-reduced-motion: reduce) {
    .artisan-entry__photo { transition: none; }
    .artisan-entry__photo:hover { transform: none; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Nos artisans",
  "settings": [
    { "type": "header", "content": "Hero de page" },
    { "type": "text",     "id": "hero_eyebrow",  "label": "Surtitre", "default": "Maison Bonjour · Les maisons" },
    { "type": "text",     "id": "hero_title",    "label": "Titre", "default": "Nos artisans" },
    { "type": "textarea", "id": "hero_subtitle", "label": "Sous-titre éditorial", "default": "Derrière chaque objet, une maison. Derrière chaque maison, des gestes que le temps n’a pas effacés." },
    { "type": "image_picker", "id": "hero_image", "label": "Visuel (artisans / atelier)", "info": "Si vide : photo des trois artisans (LouPais_artisans.jpeg)." },
    { "type": "textarea", "id": "intro", "label": "Introduction courte", "default": "Maison Bonjour ne sélectionne pas seulement des produits. Nous cherchons des maisons, des ateliers, des familles, des gestes transmis. Chaque artisan présenté ici donne à une région sa matière, son parfum ou sa mémoire." },
    { "type": "textarea", "id": "closing_note", "label": "Note de clôture (annonce futurs artisans)", "default": "D’autres maisons rejoindront bientôt cette page, au fil des prochaines éditions.", "info": "Laisser vide pour masquer." }
  ],
  "blocks": [
    {
      "type": "artisan",
      "name": "Artisan",
      "settings": [
        { "type": "text",     "id": "label", "label": "Label (région · maison)", "default": "Aubagne — Provence · Maison fondée en 1895" },
        { "type": "text",     "id": "name",  "label": "Titre / Maison", "default": "Les Faïences de Louis Sicard" },
        { "type": "richtext", "id": "body",  "label": "Récit" },
        { "type": "image_picker", "id": "image_1", "label": "Photo 1" },
        { "type": "text",     "id": "image_1_alt", "label": "Alt photo 1" },
        { "type": "image_picker", "id": "image_2", "label": "Photo 2 (optionnel)" },
        { "type": "text",     "id": "image_2_alt", "label": "Alt photo 2" }
      ]
    }
  ],
  "presets": [{ "name": "Nos artisans" }]
}
{% endschema %}
