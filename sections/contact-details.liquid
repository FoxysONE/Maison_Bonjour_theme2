{%- liquid
  assign eyebrow   = section.settings.eyebrow   | default: 'Coordonnées'
  assign title     = section.settings.title     | default: 'Maison Bonjour'
  assign address   = section.settings.address   | default: 'Strada Pavel Roșcă nr. 4, ap. 28 · 400118 Cluj-Napoca · România'
  assign email     = section.settings.email     | default: 'bonjour@maisonbonjour.ro'
  assign phone     = section.settings.phone
  assign response  = section.settings.response_time | default: 'Nous lisons chaque message et répondons sous 24 à 48 heures ouvrées.'
-%}

<section class="contact-coord section--warm" aria-labelledby="contact-coord-title-{{ section.id }}">
  <div class="container">
    <header class="contact-coord__head">
      <p class="section-marker contact-coord__marker">{{ eyebrow }}</p>
      <h2 class="contact-coord__title" id="contact-coord-title-{{ section.id }}">{{ title }}</h2>
    </header>

    <dl class="contact-coord__grid">
      {%- if address != blank -%}
        <div class="contact-coord__item">
          <dt class="contact-coord__label">{{ 'contact.details.address' | t }}</dt>
          <dd class="contact-coord__value">{{ address }}</dd>
        </div>
      {%- endif -%}

      {%- if email != blank -%}
        <div class="contact-coord__item">
          <dt class="contact-coord__label">{{ 'contact.details.email' | t }}</dt>
          <dd class="contact-coord__value">
            <a href="mailto:{{ email }}">{{ email }}</a>
          </dd>
        </div>
      {%- endif -%}

      <div class="contact-coord__item">
        <dt class="contact-coord__label">{{ 'contact.details.phone' | t }}</dt>
        <dd class="contact-coord__value">
          {%- if phone != blank -%}
            <a href="tel:{{ phone | remove: ' ' }}">{{ phone }}</a>
          {%- else -%}
            <span class="contact-coord__todo">{{ 'contact.details.todo' | t }}</span>
          {%- endif -%}
        </dd>
      </div>

      {%- if response != blank -%}
        <div class="contact-coord__item contact-coord__item--wide">
          <dt class="contact-coord__label">{{ 'contact.details.response' | t }}</dt>
          <dd class="contact-coord__value">{{ response }}</dd>
        </div>
      {%- endif -%}
    </dl>
  </div>
</section>

{% stylesheet %}
  .contact-coord {
    --cc-cream: #F5F0E8;
    --cc-marine: var(--marine, #1C2B4A);
    --cc-gold: var(--gold, #B8965A);
    --cc-line: rgba(28, 43, 74, 0.16);
    padding-block: clamp(48px, 6vw, 88px);
    background: var(--cc-cream);
    color: var(--cc-marine);
  }
  .contact-coord__head { max-width: 720px; margin: 0 0 clamp(28px, 4vw, 48px); }
  .contact-coord__marker { display: block; margin: 0 0 14px; color: var(--cc-gold); opacity: 0.85; }
  .contact-coord__title {
    margin: 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    font-size: clamp(1.7rem, 2.4vw + 0.8rem, 2.6rem);
    line-height: 1.08;
    color: var(--cc-marine);
  }
  .contact-coord__grid {
    margin: 0;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(20px, 3vw, 40px);
    border-top: 1px solid var(--cc-line);
    padding-top: clamp(24px, 3vw, 40px);
  }
  .contact-coord__item { margin: 0; }
  .contact-coord__item--wide { grid-column: 1 / -1; }
  .contact-coord__label {
    margin: 0 0 8px;
    font-family: var(--font-sans);
    font-size: 10.5px;
    font-weight: 600;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--cc-gold);
  }
  .contact-coord__value {
    margin: 0;
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 16px;
    line-height: 1.6;
    color: var(--cc-marine);
  }
  .contact-coord__value a {
    color: var(--cc-marine);
    text-decoration: none;
    border-bottom: 1px solid rgba(184, 150, 90, 0.5);
    transition: color 0.25s ease, border-color 0.25s ease;
  }
  .contact-coord__value a:hover { color: var(--cc-gold); border-color: var(--cc-gold); }
  .contact-coord__todo { font-style: italic; opacity: 0.6; }

  @media (max-width: 600px) {
    .contact-coord__grid { grid-template-columns: 1fr; gap: 20px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Contact — Coordonnées",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Surtitre", "default": "Coordonnées" },
    { "type": "text", "id": "title", "label": "Titre", "default": "Maison Bonjour" },
    { "type": "textarea", "id": "address", "label": "Adresse", "default": "Strada Pavel Roșcă nr. 4, ap. 28 · 400118 Cluj-Napoca · România" },
    { "type": "text", "id": "email", "label": "Email", "default": "bonjour@maisonbonjour.ro" },
    { "type": "text", "id": "phone", "label": "Téléphone", "info": "Laisser vide affiche « À compléter ». Ex. : +40 7XX XXX XXX." },
    { "type": "textarea", "id": "response_time", "label": "Délai de réponse", "default": "Nous lisons chaque message et répondons sous 24 à 48 heures ouvrées." }
  ],
  "presets": [{ "name": "Contact — Coordonnées" }]
}
{% endschema %}
