{%- liquid
  # Le Voyage — galerie horizontale épinglée des escales régionales.
  # On arrive sur la section, elle se fige, et le scroll fait défiler les
  # landings une à une à l'horizontal.
  #
  # ORDRE DES RÉGIONS : volontairement ÉDITORIAL / LIBRE, jamais chronologique.
  # Ce n'est PAS l'ordre des prochaines box (pas de roadmap, pas de calendrier,
  # pas de dates). Modifiable sans risque via le réglage « Ordre des régions »
  # du customizer (slugs séparés par des virgules) — réordonner ne casse rien.
  assign order_default = 'perigord,bretagne,cote-d-azur,bourgogne,provence,alsace,normandie,pays-basque,corse,val-de-loire,auvergne,champagne'
  assign region_order  = section.settings.region_order | default: order_default
  assign region_slugs  = region_order | split: ','
  assign order_caption = section.settings.order_caption | default: 'Quelques escales françaises — un voyage sans ordre imposé.'
-%}

<section class="journey-h section--dark" data-journey-h data-fm-skip
         aria-label="Le Voyage — quelques escales françaises à explorer librement, sans ordre imposé"
         style="--journey-count: {{ region_slugs.size }};">
  <div class="journey-h__sticky">

    {%- if order_caption != blank -%}
      <p class="journey-h__caption">{{ order_caption }}</p>
    {%- endif -%}

    <ol class="journey-h__track" data-journey-track role="list">
      {%- for slug in region_slugs -%}
        {%- assign slug = slug | strip -%}
        {%- assign num_padded = forloop.index | prepend: '0' | slice: -2, 2 -%}

        {%- case slug -%}
          {%- when 'provence' -%}
            {%- assign region_name = 'Provence' -%}
            {%- assign word_a = 'Cigales' -%}{%- assign word_b = 'Lavande' -%}{%- assign word_c = 'Oliviers' -%}
            {%- assign tagline = 'Il y a une lumière qui ne quitte jamais les pierres.' -%}
            {%- assign detail  = 'Une Provence lente, chaude et minérale, entre villages perchés, collines dorées et parfum d’herbes sèches.' -%}
            {%- assign image_main = 'paysage-region-provence-01.jpeg' -%}
          {%- when 'bretagne' -%}
            {%- assign region_name = 'Bretagne' -%}
            {%- assign word_a = 'Caramels salés' -%}{%- assign word_b = 'Sel marin' -%}{%- assign word_c = 'Granit' -%}
            {%- assign tagline = 'Ici, le vent polit les pierres et la mer garde les secrets.' -%}
            {%- assign detail  = 'Une Bretagne sauvage et silencieuse, entre falaises, granit, embruns et lumière changeante.' -%}
            {%- assign image_main = 'paysage-region-bretagne-01.jpeg' -%}
          {%- when 'alsace' -%}
            {%- assign region_name = 'Alsace' -%}
            {%- assign word_a = 'Vins blancs' -%}{%- assign word_b = 'Pain d’épices' -%}{%- assign word_c = 'Faïence' -%}
            {%- assign tagline = 'Des villages lumineux où l’hiver semble avoir une âme.' -%}
            {%- assign detail  = 'Une Alsace chaleureuse et artisanale, entre vignes, maisons anciennes, faïence et douceur épicée.' -%}
            {%- assign image_main = 'paysage-region-alsace-02.jpeg' -%}
          {%- when 'bourgogne' -%}
            {%- assign region_name = 'Bourgogne' -%}
            {%- assign word_a = 'Moutarde' -%}{%- assign word_b = 'Pierre dorée' -%}{%- assign word_c = 'Escargots' -%}
            {%- assign tagline = 'La France y prend le temps de vieillir avec élégance.' -%}
            {%- assign detail  = 'Une Bourgogne noble et terrienne, entre vignes profondes, villages de pierre dorée et traditions lentes.' -%}
            {%- assign image_main = 'paysage-region-bourgogne-01.jpeg' -%}
          {%- when 'pays-basque' -%}
            {%- assign region_name = 'Pays Basque' -%}
            {%- assign word_a = 'Piments' -%}{%- assign word_b = 'Lin' -%}{%- assign word_c = 'Espadrilles' -%}
            {%- assign tagline = 'Entre l’Atlantique et les collines, tout semble plus vivant.' -%}
            {%- assign detail  = 'Un Pays Basque graphique et intense, entre vagues, maisons blanches, verts profonds et savoir-faire textile.' -%}
            {%- assign image_main = 'paysage-region-pays-basque-01.jpeg' -%}
          {%- when 'normandie' -%}
            {%- assign region_name = 'Normandie' -%}
            {%- assign word_a = 'Beurre' -%}{%- assign word_b = 'Pommiers' -%}{%- assign word_c = 'Falaises' -%}
            {%- assign tagline = 'Une lumière douce descend sur les pommiers et les falaises.' -%}
            {%- assign detail  = 'Une Normandie calme et généreuse, entre herbe humide, falaises claires, vergers et brume légère.' -%}
            {%- assign image_main = 'paysage-region-normandie-01.jpeg' -%}
          {%- when 'perigord' -%}
            {%- assign region_name = 'Périgord' -%}
            {%- assign word_a = 'Truffes' -%}{%- assign word_b = 'Noix' -%}{%- assign word_c = 'Châtaigneraies' -%}
            {%- assign tagline = 'Les vallées gardent le goût ancien des maisons de pierre.' -%}
            {%- assign detail  = 'Un Périgord profond et doré, entre forêts, rivières, châteaux, noix et gastronomie de mémoire.' -%}
            {%- assign image_main = 'paysage-region-perigord-02.jpeg' -%}
          {%- when 'auvergne' -%}
            {%- assign region_name = 'Auvergne' -%}
            {%- assign word_a = 'Fromages' -%}{%- assign word_b = 'Volcans' -%}{%- assign word_c = 'Coutellerie' -%}
            {%- assign tagline = 'Sous les volcans endormis, la terre respire encore.' -%}
            {%- assign detail  = 'Une Auvergne brute et majestueuse, entre pâturages, reliefs volcaniques, fromages et artisanat robuste.' -%}
            {%- assign image_main = 'paysage-region-auvergne-01.jpeg' -%}
          {%- when 'champagne' -%}
            {%- assign region_name = 'Champagne' -%}
            {%- assign word_a = 'Bulles' -%}{%- assign word_b = 'Craie' -%}{%- assign word_c = 'Royauté' -%}
            {%- assign tagline = 'Une fête silencieuse dort sous les collines de craie.' -%}
            {%- assign detail  = 'Une Champagne élégante et précise, entre vignes ordonnées, sols crayeux, caves et héritage royal.' -%}
            {%- assign image_main = 'paysage-region-champagne-01.jpeg' -%}
          {%- when 'cote-d-azur' -%}
            {%- assign region_name = 'Côte d’Azur' -%}
            {%- assign word_a = 'Parfums' -%}{%- assign word_b = 'Savons' -%}{%- assign word_c = 'Méditerranée' -%}
            {%- assign tagline = 'Le Sud commence là où la mer devient lumière.' -%}
            {%- assign detail  = 'Une Côte d’Azur solaire et magnifiée, entre criques transparentes, villages perchés, pins et reliefs méditerranéens.' -%}
            {%- assign image_main = 'paysage-region-cote-d-azur-01.jpeg' -%}
          {%- when 'val-de-loire' -%}
            {%- assign region_name = 'Val de Loire' -%}
            {%- assign word_a = 'Vouvray' -%}{%- assign word_b = 'Tuffeau' -%}{%- assign word_c = 'Jardins' -%}
            {%- assign tagline = 'La douceur française avance au rythme lent du fleuve.' -%}
            {%- assign detail  = 'Un Val de Loire élégant et classique, entre châteaux, jardins, tuffeau clair, vignes et rivières.' -%}
            {%- assign image_main = 'paysage-region-val-de-loire-01.jpeg' -%}
          {%- when 'corse' -%}
            {%- assign region_name = 'Corse' -%}
            {%- assign word_a = 'Charcuteries' -%}{%- assign word_b = 'Immortelle' -%}{%- assign word_c = 'Maquis' -%}
            {%- assign tagline = 'Une île où la montagne tombe dans la mer.' -%}
            {%- assign detail  = 'Une Corse sauvage et raffinée, entre maquis, criques transparentes, villages perchés et lumière minérale.' -%}
            {%- assign image_main = 'paysage-region-corse-01.jpeg' -%}
        {%- endcase -%}

        <li class="journey-slide" data-journey-slide aria-label="{{ region_name }}">
          <article class="region-edition" aria-labelledby="region-name-{{ slug }}">

            <div class="region-edition__media" aria-hidden="true">
              <img class="region-edition__img"
                   src="{{ image_main | asset_url }}"
                   alt=""
                   loading="lazy"
                   decoding="async"
                   width="2000"
                   height="1200">
              <span class="region-edition__overlay"></span>
              <span class="region-edition__vignette"></span>
            </div>

            <div class="region-edition__frame">

              <div class="region-edition__center reveal">
                <p class="region-edition__headline"><em>{{ tagline }}</em></p>
              </div>

              <div class="region-edition__bottom reveal reveal--delay-1">
                <h3 class="region-edition__name" id="region-name-{{ slug }}">
                  <span class="region-edition__name-text">{{ region_name | upcase }}</span>
                </h3>
                <aside class="region-edition__aside">
                  <ul class="region-edition__keywords" role="list" aria-label="Trois mots-clés">
                    <li>{{ word_a }}</li>
                    <li aria-hidden="true" class="region-edition__sep">·</li>
                    <li>{{ word_b }}</li>
                    <li aria-hidden="true" class="region-edition__sep">·</li>
                    <li>{{ word_c }}</li>
                  </ul>
                  <p class="region-edition__desc">{{ detail }}</p>
                </aside>
              </div>

            </div>
          </article>
        </li>
      {%- endfor -%}
    </ol>

    <div class="journey-h__progress" aria-hidden="true">
      <span class="journey-h__index" data-journey-index>01</span>
      <span class="journey-h__bar"><span class="journey-h__fill" data-journey-fill></span></span>
      <span class="journey-h__total">{{ region_slugs.size }}</span>
      {%- comment -%} Indice de glissement (mobile uniquement) : trait + micro-flèche, se masque au premier swipe. {%- endcomment -%}
      <span class="journey-h__hint" data-journey-hint aria-hidden="true">
        <span class="journey-h__hint-line"></span>
        <span class="journey-h__hint-arrow">&rarr;</span>
      </span>
    </div>

  </div>
</section>

{% stylesheet %}
  /* ============================================================
     LE VOYAGE — galerie horizontale épinglée
     12 slides plein écran. Le conteneur haut donne la distance de
     scroll ; le viewport sticky se fige ; la piste se translate.
     ============================================================ */

  /* La section haute fournit la DISTANCE de scroll ; le viewport interne se
     fige (position: sticky) et la piste se translate horizontalement en
     fonction de la position de scroll (piloté par JS, lissé par Lenis).
     → Pas de capture de molette : le défilement reste libre et fluide.
       Un snap « à l'arrêt » (JS) recale ensuite sur une région à la fois, pour
       ne jamais rester immobilisé entre deux. Arrivée et sortie restent
       naturelles (le snap n'agit qu'à l'intérieur de la galerie épinglée).
     IMPORTANT : pas d'overflow:hidden sur .journey-h (cela casserait le sticky). */
  .journey-h {
    position: relative;
    height: calc(100vh + (var(--journey-count, 12) - 1) * 56vh);
    background: var(--marine-deep);
  }

  .journey-h__sticky {
    position: sticky;
    top: 0;
    height: 100vh;
    height: 100dvh;
    overflow: hidden;
  }

  .journey-h__track {
    display: flex;
    flex-wrap: nowrap;
    height: 100%;
    margin: 0;
    padding: 0;
    list-style: none;
    width: max-content;
    will-change: transform;
    /* Translation pilotée par le scroll (JS) : pas de transition CSS, le
       lissage vient de Lenis → glissement continu et fluide. */
  }

  /* Contenu des slides toujours visible : l'entrée se fait par la translation
     horizontale (l'IntersectionObserver de .reveal ne suit pas le transform). */
  .journey-h .reveal { opacity: 1; transform: none; }

  .journey-slide {
    flex: 0 0 100vw;
    width: 100vw;
    height: 100%;
  }

  /* ---- La landing immersive (reprise des codes du hero) ---- */
  .region-edition {
    position: relative;
    width: 100%;
    height: 100%;
    overflow: hidden;
    color: var(--text-cream);
    isolation: isolate;
  }

  .region-edition__media { position: absolute; inset: 0; z-index: 0; }
  .region-edition__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    transform: scale(1.06);
    transition: transform 1.4s var(--ease-cinema);
  }
  .journey-slide.is-active .region-edition__img { transform: scale(1); }

  .region-edition__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg,
      rgba(15, 26, 46, 0.55) 0%,
      rgba(15, 26, 46, 0.22) 30%,
      rgba(15, 26, 46, 0.5) 58%,
      rgba(15, 26, 46, 0.82) 80%,
      rgba(15, 26, 46, 0.96) 100%);
  }
  .region-edition__vignette {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse at center, transparent 52%, rgba(15, 26, 46, 0.45) 100%);
    pointer-events: none;
  }

  .region-edition__frame {
    position: relative;
    z-index: 2;
    height: 100%;
    display: grid;
    grid-template-rows: auto 1fr auto;
    padding: clamp(28px, 5vh, 64px) clamp(24px, 5vw, 96px) clamp(36px, 6vh, 72px);
  }

  .region-edition__kicker {
    margin: 0;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: rgba(250, 246, 236, 0.78);
  }

  .region-edition__center {
    align-self: center;
    /* plus long : la phrase s'étale sur 1–2 lignes au lieu de 3 */
    max-width: min(48ch, 90%);
    /* descend légèrement vers le milieu de l'image */
    margin-top: clamp(40px, 12vh, 150px);
  }
  .region-edition__headline {
    margin: 0;
    font-family: var(--font-serif);
    font-style: italic;
    font-weight: 400;
    /* taille réduite et plus aérée → plus lisible sur le paysage */
    font-size: clamp(1.5rem, 1.6vw + 0.9rem, 2.6rem);
    line-height: 1.3;
    letter-spacing: -0.005em;
    text-wrap: balance;
    /* ombre plus dense pour le contraste sur les fonds clairs */
    text-shadow: 0 2px 10px rgba(15, 26, 46, 0.9), 0 4px 40px rgba(15, 26, 46, 0.7);
  }
  .region-edition__headline em { font-style: italic; }

  .region-edition__bottom {
    display: grid;
    grid-template-columns: 1fr;
    gap: 20px;
    align-items: end;
  }

  .region-edition__name { margin: 0; }
  .region-edition__name-text {
    display: inline-block;
    font-family: "TAN Pearl", "Instrument Serif", serif;
    font-weight: 700;
    font-size: clamp(2.6rem, 7.5vw, 6.5rem);
    line-height: 0.98;
    letter-spacing: -0.01em;
    color: var(--cream);
    text-shadow: 0 2px 14px rgba(15, 26, 46, 0.75), 0 8px 60px rgba(15, 26, 46, 0.5);
  }

  .region-edition__aside { max-width: 420px; }
  .region-edition__keywords {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin: 0 0 12px;
    padding: 0;
    list-style: none;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--gold-soft);
  }
  .region-edition__sep { color: rgba(250, 246, 236, 0.4); }
  .region-edition__desc {
    margin: 0;
    font-family: var(--font-sans);
    font-weight: 300;
    font-size: 15px;
    line-height: 1.7;
    color: rgba(250, 246, 236, 0.82);
  }

  @media (min-width: 768px) {
    .region-edition__bottom {
      grid-template-columns: 1fr auto;
      gap: 48px;
      align-items: flex-end;
    }
    .region-edition__aside { text-align: right; }
    .region-edition__keywords { justify-content: flex-end; }
  }

  /* ---- Indicateur de progression ---- */
  .journey-h__progress {
    position: absolute;
    left: 50%;
    bottom: clamp(18px, 3vh, 32px);
    transform: translateX(-50%);
    z-index: 5;
    display: flex;
    align-items: center;
    gap: 14px;
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.2em;
    color: rgba(250, 246, 236, 0.72);
  }
  .journey-h__bar {
    position: relative;
    width: 120px;
    height: 1px;
    background: rgba(250, 246, 236, 0.25);
    overflow: hidden;
  }
  .journey-h__fill {
    position: absolute;
    inset: 0 auto 0 0;
    width: 8%;
    background: var(--gold);
    transition: width 0.25s var(--ease-out);
  }
  .journey-h__index { color: var(--cream); }

  /* Mention discrète en haut : cadre le carousel comme un voyage LIBRE
     (pas un ordre/roadmap des prochaines box). Décorative, n'affecte pas le scroll. */
  .journey-h__caption {
    position: absolute;
    top: clamp(18px, 3.5vh, 40px);
    left: 50%;
    transform: translateX(-50%);
    z-index: 5;
    margin: 0;
    max-width: min(90%, 640px);
    text-align: center;
    font-family: var(--font-sans);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: rgba(250, 246, 236, 0.72);
    pointer-events: none;
  }

  /* Indice de glissement — masqué sur desktop (le scroll suffit), affiché mobile. */
  .journey-h__hint { display: none; }

  /* ============================================================
     MOBILE — scroll-snap horizontal natif (swipe), pas d'épinglage
     ============================================================ */
  @media (max-width: 767px) {
    .journey-h { height: auto; }
    .journey-h__sticky { position: static; height: auto; overflow: visible; }
    /* Mention en flux normal au-dessus du carousel (plus d'absolu sur mobile). */
    .journey-h__caption {
      position: static;
      transform: none;
      max-width: 100%;
      padding: 22px 20px 14px;
      font-size: 10px;
      letter-spacing: 0.22em;
    }
    .journey-h__track {
      width: auto;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .journey-h__track::-webkit-scrollbar { display: none; }
    .journey-slide {
      height: 86vh;
      scroll-snap-align: center;
      scroll-snap-stop: always;
    }
    .region-edition__img { transform: scale(1); }
    .journey-h__progress {
      position: static;
      transform: none;
      justify-content: center;
      padding: 18px 0 4px;
    }
    .journey-h__hint {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      margin-left: 12px;
      transition: opacity 0.45s ease;
    }
    .journey-h__hint.is-hidden { opacity: 0; }
    .journey-h__hint-line {
      width: 22px;
      height: 1px;
      background: rgba(250, 246, 236, 0.4);
    }
    .journey-h__hint-arrow {
      color: var(--gold-soft);
      font-size: 13px;
      line-height: 1;
      animation: journeyNudge 1.9s ease-in-out infinite;
    }
  }

  @keyframes journeyNudge {
    0%, 100% { transform: translateX(0); opacity: 0.55; }
    50%      { transform: translateX(5px); opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .journey-h__hint-arrow { animation: none; }
  }

  /* ============================================================
     REDUCED MOTION — empilement vertical, tout reste visible
     ============================================================ */
  @media (prefers-reduced-motion: reduce) {
    .journey-h { height: auto; }
    .journey-h__sticky { position: static; height: auto; overflow: visible; }
    .journey-h__track { flex-direction: column; width: auto; }
    .journey-slide { width: 100%; height: 84vh; }
    .region-edition__img { transform: scale(1); transition: none; }
    .journey-h__progress { display: none; }
  }
{% endstylesheet %}

{% javascript %}
  (function () {
    var section = document.querySelector('[data-journey-h]');
    if (!section) return;
    var track   = section.querySelector('[data-journey-track]');
    var slides  = section.querySelectorAll('[data-journey-slide]');
    var indexEl = section.querySelector('[data-journey-index]');
    var fillEl  = section.querySelector('[data-journey-fill]');
    var hintEl  = section.querySelector('[data-journey-hint]');
    if (!track || !slides.length) return;

    var count = slides.length;
    var mq = window.matchMedia('(min-width: 768px)');
    var rm = window.matchMedia('(prefers-reduced-motion: reduce)');
    // Mode épinglé (desktop / tablette, mouvement autorisé) : le viewport est figé
    // par `position: sticky` (CSS) et la piste se translate selon la POSITION de
    // scroll. Aucune capture de molette, aucun gel de Lenis → arrivée et sortie
    // naturelles, défilement fluide, pas de coup sec ni de blocage.
    // Sinon (mobile ≤767 / reduced-motion) : scroll horizontal natif ou empilement.
    function pinned() { return mq.matches && !rm.matches; }
    function pad(n) { return n < 10 ? '0' + n : '' + n; }
    function clamp(v, a, b) { return v < a ? a : (v > b ? b : v); }

    var lastIdx = -1;
    var ticking = false;

    function setActive(idx) {
      for (var i = 0; i < slides.length; i++) {
        slides[i].classList.toggle('is-active', i === idx);
      }
    }

    function render() {
      if (!pinned()) return;
      var rect = section.getBoundingClientRect();
      var scrollable = section.offsetHeight - window.innerHeight;
      var p = scrollable > 0 ? clamp(-rect.top / scrollable, 0, 1) : 0;
      track.style.transform = 'translate3d(' + (-p * (count - 1) * 100) + 'vw, 0, 0)';
      if (fillEl) fillEl.style.width = (p * 100) + '%';
      var idx = Math.round(p * (count - 1));
      if (idx !== lastIdx) {
        lastIdx = idx;
        if (indexEl) indexEl.textContent = pad(idx + 1);
        setActive(idx);
      }
    }

    // ---- Snap « à l'arrêt » (desktop épinglé uniquement) -------------------
    // Le scroll fait glisser la piste en continu ; sans règle, on peut
    // s'immobiliser entre deux régions. On recale sur la région la plus proche,
    // une à une, MAIS seulement quand le mouvement est réellement terminé —
    // sinon on lutterait contre l'inertie de Lenis (sensation de bug).
    // Garde-fous contre ce combat :
    //   • on ne snape que si la vitesse de scroll est ~nulle (mesurée frame/frame) ;
    //   • tout nouveau geste utilisateur (molette / trackpad / clavier) ANNULE
    //     immédiatement un recalage en cours → la molette n'est jamais capturée ;
    //   • un garde-fou (timeout) remet toujours l'état à zéro.
    // On ne snape qu'à l'INTÉRIEUR de la galerie épinglée (arrivée/sortie
    // naturelles) et jamais pendant une nav par ancre (window.__mbAnchorNav).
    var SNAP_IDLE = 160;  // ms sans geste utilisateur avant d'autoriser le calage
    var SNAP_VMAX = 1.5;  // px/frame : au-dessus, ça bouge encore → on attend
    var SNAP_MIN  = 6;    // px : en deçà, on est déjà calé
    var SNAP_STEP = 0.14; // fraction de région à dépasser pour valider la suivante
    var restIdx   = 0;    // région sur laquelle on était posé (pour le sens du calage)
    var lastInput  = 0;
    var lastY      = window.pageYOffset;
    var velY       = 0;
    var snapping   = false;
    var snapSafety = null;
    var settleTimer = null;

    function nowMs() { return Date.now(); }

    function endSnap() {
      snapping = false;
      if (snapSafety) { window.clearTimeout(snapSafety); snapSafety = null; }
    }

    // Recale restIdx sur la région réellement à l'écran (refresh / resize).
    function syncRest() {
      var rect = section.getBoundingClientRect();
      var scrollable = section.offsetHeight - window.innerHeight;
      if (scrollable <= 0) { restIdx = 0; return; }
      restIdx = clamp(Math.round(clamp(-rect.top / scrollable, 0, 1) * (count - 1)), 0, count - 1);
    }

    // Un geste de l'utilisateur reprend toujours la main sur un snap en cours.
    function onUserInput() {
      lastInput = nowMs();
      if (snapping) endSnap();
    }
    ['wheel', 'touchstart', 'touchmove', 'keydown'].forEach(function (ev) {
      window.addEventListener(ev, onUserInput, { passive: true });
    });

    function maybeSnap() {
      if (!pinned() || snapping || count < 2) return;
      if (window.__mbAnchorNav) return;                 // nav par ancre en cours
      if (nowMs() - lastInput < SNAP_IDLE) return;      // l'utilisateur agit encore
      if (Math.abs(velY) > SNAP_VMAX) return;           // ça glisse encore (Lenis)
      var rect = section.getBoundingClientRect();
      var scrollable = section.offsetHeight - window.innerHeight;
      if (scrollable <= 0) return;
      // Hors galerie épinglée (en approche ou déjà dépassée) : on ne touche à rien.
      if (rect.top > 0 || -rect.top > scrollable) return;
      var p = clamp(-rect.top / scrollable, 0, 1);
      var stepPos = p * (count - 1);     // position continue (ex. 3.2 = région 3 + 0.2)
      var idx;
      // À moins d'une région d'écart : on VALIDE dans le sens du geste dès qu'on
      // a dépassé un petit seuil → un coup de molette fait avancer d'une région
      // (au lieu de revenir en arrière, ce qui donnait l'impression de blocage).
      // Au-delà d'une région d'écart (gros scroll) : on cale sur la plus proche.
      if (Math.abs(stepPos - restIdx) <= 1) {
        if (stepPos > restIdx + SNAP_STEP) idx = restIdx + 1;
        else if (stepPos < restIdx - SNAP_STEP) idx = restIdx - 1;
        else idx = restIdx;
      } else {
        idx = Math.round(stepPos);
      }
      idx = clamp(idx, 0, count - 1);
      var target = (rect.top + window.pageYOffset) + (idx / (count - 1)) * scrollable;
      if (Math.abs(target - window.pageYOffset) < SNAP_MIN) { restIdx = idx; return; } // déjà calé
      restIdx = idx;
      snapping = true;
      snapSafety = window.setTimeout(function () { endSnap(); render(); }, 1100);
      var release = function () { endSnap(); render(); };
      var lenis = window.__mbLenis;
      if (lenis && typeof lenis.scrollTo === 'function') {
        // Recalage plus long + easing doux (ease-in-out) → glissement velouté
        // jusqu'à la région, sans départ ni arrêt secs.
        lenis.scrollTo(target, {
          duration: 0.72,
          easing: function (t) {
            return t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;
          },
          onComplete: release
        });
      } else {
        window.scrollTo({ top: target, behavior: 'smooth' });
      }
    }

    function onScroll() {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(function () {
        ticking = false;
        var y = window.pageYOffset;
        velY = y - lastY;
        lastY = y;
        render();
        maybeSnap();
      });
      // Filet : quand les événements de scroll cessent complètement, on
      // considère le mouvement terminé (velY = 0) et on retente une fois.
      if (settleTimer) window.clearTimeout(settleTimer);
      settleTimer = window.setTimeout(function () {
        velY = 0;
        maybeSnap();
      }, SNAP_IDLE + 40);
    }
    window.addEventListener('scroll', onScroll, { passive: true });

    function onResize() {
      endSnap();
      if (settleTimer) { window.clearTimeout(settleTimer); settleTimer = null; }
      lastY = window.pageYOffset;
      velY = 0;
      if (!pinned()) { track.style.transform = ''; }
      lastIdx = -1;
      syncRest();
      render();
    }
    window.addEventListener('resize', onResize, { passive: true });
    if (mq.addEventListener) {
      mq.addEventListener('change', onResize);
      rm.addEventListener('change', onResize);
    }

    // Indicateur mobile : progression depuis le scroll horizontal natif + masquage du hint.
    track.addEventListener('scroll', function () {
      if (pinned()) return;
      window.requestAnimationFrame(function () {
        var max = track.scrollWidth - track.clientWidth;
        var p = max > 0 ? track.scrollLeft / max : 0;
        var idx = Math.round(p * (count - 1));
        if (indexEl) indexEl.textContent = pad(idx + 1);
        if (fillEl) fillEl.style.width = (p * 100) + '%';
        if (hintEl && track.scrollLeft > 8) hintEl.classList.add('is-hidden');
      });
    }, { passive: true });

    // État initial + recalage après chargement complet (hauteurs définitives).
    if (pinned()) { syncRest(); render(); } else { setActive(0); }
    window.addEventListener('load', function () { lastIdx = -1; syncRest(); render(); });
  })();
{% endjavascript %}

